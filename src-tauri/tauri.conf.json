{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "prebucket",
	"version": "0.1.0",
	"identifier": "pre.bucket",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm generate",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Prebucket",
				"width": 800,
				"height": 600,
				"minWidth": 600,
				"minHeight": 480,
				"decorations": false,
				"dragDropEnabled": false
			}
		],
		"security": {
			"csp": {
				"default-src": "'self'",
				"connect-src": "ipc: http://ipc.localhost http://tauri.localhost https://tauri.localhost https:",
				"script-src": "'strict-dynamic' 'unsafe-eval' 'wasm-unsafe-eval' 'unsafe-inline' https:",
				"img-src": "'self' blob: data: http://tauri.localhost https://tauri.localhost https:",
				"style-src": "'self' 'unsafe-inline'",
				"font-src": "'self'",
				"worker-src": "'self' blob:"
			}
		},
		"withGlobalTauri": true
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"publisher": "PRE"
	}
}
